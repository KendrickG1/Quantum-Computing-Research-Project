<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Quantum Frontier | Alabama & Global Research</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        // Tailwind Configuration for Dark Mode
        tailwind.config = {
            darkMode: 'class',
        }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap');
        body { font-family: 'Inter', sans-serif; transition: background-color 0.3s ease, color 0.3s ease; }
        .glass-card {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(226, 232, 240, 0.8);
        }
        .dark .glass-card {
            background: rgba(30, 41, 59, 0.8);
            border: 1px solid rgba(51, 65, 85, 0.8);
        }
        .media-gradient {
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
        }
        .article-card:hover {
            transform: translateY(-4px);
            transition: all 0.3s ease;
        }
        /* Modal Animation */
        .modal-active { opacity: 1; transform: scale(1); transition: all 0.2s ease-out; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 dark:bg-slate-950 dark:text-slate-100">

    <!-- Hero Section -->
    <header class="relative bg-slate-900 py-20 px-6 overflow-hidden">
        <div class="absolute inset-0 opacity-20">
            <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-blue-500 via-transparent to-transparent"></div>
        </div>
        <div class="max-w-5xl mx-auto relative z-10 text-center">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-400 text-sm font-medium mb-6">
                <i data-lucide="search" class="w-4 h-4"></i>
                <span>2026 Research Update</span>
            </div>
            <h1 class="text-4xl md:text-6xl font-extrabold text-white mb-6 tracking-tight leading-tight">
                The Quantum <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-300">Frontier</span>
            </h1>
            <p class="text-xl text-slate-400 max-w-2xl mx-auto">
                Exploring the synergy between Quantum Science and Computing—where industrial innovation meets academic breakthroughs.
            </p>
        </div>
    </header>

    <main class="max-w-6xl mx-auto px-6 py-12">
        
        <!-- Learning the Correlation Section -->
        <section class="mb-20">
            <div class="text-center mb-10">
                <h2 class="text-3xl font-bold mb-4">Quantum Science vs. Computing</h2>
                <p class="text-slate-500 max-w-2xl mx-auto">Understanding how the study of the very small (Science) leads to the most powerful tools ever made (Computing).</p>
            </div>
            
            <div class="grid md:grid-cols-2 gap-8">
                <div class="bg-blue-50 dark:bg-blue-900/20 p-8 rounded-3xl border border-blue-100 dark:border-blue-800">
                    <div class="w-12 h-12 bg-blue-500 text-white rounded-2xl flex items-center justify-center mb-6">
                        <i data-lucide="microscope"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-3 text-blue-700 dark:text-blue-400">Quantum Science</h3>
                    <p class="text-slate-600 dark:text-slate-400 mb-4 leading-relaxed italic">"The Foundation"</p>
                    <ul class="space-y-3 text-sm text-slate-700 dark:text-slate-300">
                        <li class="flex items-start gap-2"><i data-lucide="check-circle" class="w-4 h-4 text-blue-500 mt-1"></i> Deals with the physics of particles at the atomic and sub-atomic levels.</li>
                        <li class="flex items-start gap-2"><i data-lucide="check-circle" class="w-4 h-4 text-blue-500 mt-1"></i> Discovers the "rules" of the universe, like entanglement and wave-particle duality.</li>
                        <li class="flex items-start gap-2"><i data-lucide="check-circle" class="w-4 h-4 text-blue-500 mt-1"></i> Research Focus: Auburn's work on "Electrides" explores these fundamental rules.</li>
                    </ul>
                </div>

                <div class="bg-indigo-50 dark:bg-indigo-900/20 p-8 rounded-3xl border border-indigo-100 dark:border-indigo-800">
                    <div class="w-12 h-12 bg-indigo-500 text-white rounded-2xl flex items-center justify-center mb-6">
                        <i data-lucide="binary"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-3 text-indigo-700 dark:text-indigo-400">Quantum Computing</h3>
                    <p class="text-slate-600 dark:text-slate-400 mb-4 leading-relaxed italic">"The Application"</p>
                    <ul class="space-y-3 text-sm text-slate-700 dark:text-slate-300">
                        <li class="flex items-start gap-2"><i data-lucide="check-circle" class="w-4 h-4 text-indigo-500 mt-1"></i> Uses those "rules" to process information millions of times faster than today's PCs.</li>
                        <li class="flex items-start gap-2"><i data-lucide="check-circle" class="w-4 h-4 text-indigo-500 mt-1"></i> Converts scientific theories into actual hardware (Qubits) to solve problems.</li>
                        <li class="flex items-start gap-2"><i data-lucide="check-circle" class="w-4 h-4 text-indigo-500 mt-1"></i> Industry Spotlight: IBM's Eagle and Osprey processors apply these sciences at scale.</li>
                    </ul>
                </div>
            </div>

            <div class="mt-8 bg-slate-900 text-white p-8 rounded-3xl relative overflow-hidden">
                <div class="relative z-10 flex flex-col md:flex-row items-center gap-6">
                    <div class="flex-1 text-center md:text-left">
                        <h4 class="text-xl font-bold mb-2">The Correlation</h4>
                        <p class="text-slate-300 text-sm leading-relaxed">Think of <strong>Science</strong> as the "musical notes" and <strong>Computing</strong> as the "orchestra." You need the notes to understand harmony, but you need the orchestra to play the symphony. We use the science of particles to orchestrate data in ways classical math never could.</p>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="px-6 py-3 rounded-full bg-blue-500 text-xs font-bold uppercase tracking-widest">Observe</div>
                        <i data-lucide="arrow-right"></i>
                        <div class="px-6 py-3 rounded-full bg-indigo-500 text-xs font-bold uppercase tracking-widest">Apply</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- VERIFIED ARTICLES SECTION -->
        <section class="mb-20">
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h2 class="text-2xl font-bold flex items-center gap-2">
                        <i data-lucide="library" class="text-emerald-600"></i>
                        Verified Reading Room
                    </h2>
                    <p class="text-slate-500 text-sm mt-1">Read summaries here or follow the links to full official papers.</p>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="article-grid">
                <!-- Articles populated by JS -->
            </div>
        </section>

        <!-- Innovation Highlights -->
        <section class="mb-20">
            <h2 class="text-2xl font-bold mb-8 flex items-center gap-2">
                <i data-lucide="globe" class="text-blue-600"></i>
                Key Contributions to Quantum Computing
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- IBM Contribution -->
                <div class="flex bg-white dark:bg-slate-900 rounded-3xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm hover:shadow-md transition-all">
                    <div class="w-3 bg-blue-700"></div>
                    <div class="p-8 flex-1">
                        <div class="flex justify-between items-start mb-4">
                            <span class="text-xs font-bold text-blue-700 dark:text-blue-400 uppercase tracking-widest">IBM Quantum Industry Leader</span>
                            <div class="p-2 bg-blue-50 dark:bg-blue-900/40 rounded-lg text-blue-700"><i data-lucide="cpu"></i></div>
                        </div>
                        <h3 class="text-xl font-bold mb-3">The Era of Quantum Utility</h3>
                        <p class="text-slate-600 dark:text-slate-400 text-sm mb-4 leading-relaxed">
                            IBM recently reached "Quantum Utility," where their 127-qubit Eagle processor solved a complex physics problem that outperformed leading classical approximations. They are pioneering the first modular quantum computer, the IBM Quantum System Two, which scales computing power by linking multiple processors together.
                        </p>
                        <a href="https://www.ibm.com/quantum" target="_blank" class="inline-flex items-center gap-2 text-blue-700 dark:text-blue-400 font-bold text-xs uppercase hover:underline">
                            Explore IBM Quantum Roadmap <i data-lucide="external-link" class="w-3 h-3"></i>
                        </a>
                    </div>
                </div>
                
                <!-- Auburn Contribution -->
                <div class="flex bg-white dark:bg-slate-900 rounded-3xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm hover:shadow-md transition-all">
                    <div class="w-3 bg-orange-600"></div>
                    <div class="p-8 flex-1">
                        <div class="flex justify-between items-start mb-4">
                            <span class="text-xs font-bold text-orange-600 dark:text-orange-400 uppercase tracking-widest">Auburn & Material Science</span>
                            <div class="p-2 bg-orange-50 dark:bg-orange-900/40 rounded-lg text-orange-600"><i data-lucide="beaker"></i></div>
                        </div>
                        <h3 class="text-xl font-bold mb-3">Surface Immobilized Electrides</h3>
                        <p class="text-slate-600 dark:text-slate-400 text-sm mb-4 leading-relaxed">
                            Auburn's Department of Physics is pioneering the use of "Electrides"—materials where electrons act as anions. This breakthrough in Quantum Science allows for the creation of qubits that are protected from external interference, a key step toward the first "error-free" quantum computer.
                        </p>
                        <a href="https://www.auburn.edu/cosam/departments/physics/index.htm" target="_blank" class="inline-flex items-center gap-2 text-orange-600 dark:text-orange-400 font-bold text-xs uppercase hover:underline">
                            View Auburn Physics Research <i data-lucide="external-link" class="w-3 h-3"></i>
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Multimedia Section -->
        <section class="mb-16">
            <h2 class="text-2xl font-bold mb-8 flex items-center gap-2">
                <i data-lucide="play-circle" class="text-red-500"></i>
                Visual Summaries
            </h2>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                <div class="media-gradient rounded-3xl p-6 shadow-xl border border-slate-700">
                    <div class="flex items-center gap-3 mb-4 text-white">
                        <i data-lucide="video" class="text-blue-400"></i>
                        <h3 class="font-bold text-lg">Industry Innovation</h3>
                    </div>
                    <div class="aspect-video bg-black/40 rounded-xl overflow-hidden border border-slate-600 flex items-center justify-center relative">
                        <div class="text-slate-500 text-center p-4">
                            <i data-lucide="clapperboard" class="w-12 h-12 mx-auto mb-2 opacity-20"></i>
                            <p class="text-xs italic">Video Content Placeholder: Visualizing the IBM Quantum System Two</p>
                        </div>
                    </div>
                </div>

                <div class="bg-white dark:bg-slate-900 rounded-3xl p-6 shadow-sm border border-slate-200 dark:border-slate-800 flex flex-col justify-between">
                    <div>
                        <div class="flex items-center gap-3 mb-4 text-slate-900 dark:text-white">
                            <i data-lucide="mic" class="text-indigo-600"></i>
                            <h3 class="font-bold text-lg">Quantum Scrambling Podcast</h3>
                        </div>
                        <p class="text-slate-600 dark:text-slate-400 text-sm mb-6 leading-relaxed">
                            Deep-dive on the latest hardware breakthroughs: Why cooling systems are as important as the chips themselves.
                        </p>
                    </div>
                    <div class="bg-slate-50 dark:bg-slate-800 p-6 rounded-2xl border border-slate-100 dark:border-slate-700">
                        <div class="flex items-center gap-4 text-slate-400 italic text-xs">
                             <i data-lucide="audio-lines" class="text-indigo-500"></i>
                             <span>Audio Summary of the 2026 Hardware Summit</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <!-- Modal Overlay for Reading -->
    <div id="reader-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-slate-950/80 backdrop-blur-sm">
        <div class="bg-white dark:bg-slate-900 w-full max-w-2xl rounded-3xl shadow-2xl overflow-hidden max-h-[90vh] flex flex-col">
            <div class="p-6 border-b border-slate-100 dark:border-slate-800 flex justify-between items-center">
                <div id="modal-category" class="text-[10px] font-bold uppercase tracking-widest py-1 px-2 rounded bg-slate-100 dark:bg-slate-800">Category</div>
                <button onclick="closeReader()" class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-full transition-colors">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
            <div class="p-8 overflow-y-auto">
                <h2 id="modal-title" class="text-2xl font-bold mb-4">Article Title</h2>
                <div id="modal-content" class="text-slate-600 dark:text-slate-400 leading-relaxed space-y-4"></div>
            </div>
            <div class="p-6 bg-slate-50 dark:bg-slate-800/50 flex flex-col sm:flex-row justify-between items-center gap-4">
                <div class="flex items-center gap-2">
                    <i data-lucide="shield-check" class="w-4 h-4 text-emerald-500"></i>
                    <span class="text-xs text-slate-500 font-medium">Verified Science Source (2025-2026)</span>
                </div>
                <a id="modal-link" href="#" target="_blank" class="flex items-center gap-2 px-6 py-2 bg-indigo-600 text-white rounded-xl text-xs font-bold hover:bg-indigo-500 transition-colors shadow-lg shadow-indigo-500/20">
                    Visit Official Source <i data-lucide="external-link" class="w-3 h-3"></i>
                </a>
            </div>
        </div>
    </div>

    <!-- Theme Toggle -->
    <button id="theme-toggle" class="fixed bottom-6 right-6 w-14 h-14 bg-slate-900 text-white dark:bg-white dark:text-slate-900 rounded-full shadow-2xl flex items-center justify-center transition-all hover:scale-110 active:scale-95 z-40 border-4 border-slate-100 dark:border-slate-800">
        <i data-lucide="sun" id="sun-icon" class="hidden"></i>
        <i data-lucide="moon" id="moon-icon"></i>
    </button>

    <footer class="bg-slate-900 text-slate-400 py-16 px-6">
        <div class="max-w-6xl mx-auto text-center border-t border-slate-800 pt-8">
            <p class="text-[10px] uppercase tracking-widest">Quantum Science & Computing Portfolio • Version 3.2.0</p>
        </div>
    </footer>

    <script>
        const articles = [
            {
                id: 1,
                category: "Core Science",
                color: "emerald",
                link: "https://www.frontiersin.org/journals/quantum-science-and-technology",
                title: "Quantum Computing: Foundations & Emerging Applications",
                summary: "A verified review of qubit concepts (superposition, entanglement) and algorithms.",
                content: `
                    <p>Quantum computing relies on two main principles: <strong>Superposition</strong> and <strong>Entanglement</strong>.</p>
                    <p><strong>Superposition:</strong> This is the science of a particle being in two places at once. In computing, it allows us to test millions of solutions at the same time.</p>
                    <p><strong>Entanglement:</strong> This is the science of "spooky action at a distance," where two particles are linked. In computing, it lets us share data instantly across a processor.</p>
                    <p>Research confirms that these scientific laws allow for a "Quantum Advantage"—calculating things in seconds that take a regular computer thousands of years.</p>
                `
            },
            {
                id: 2,
                category: "Materials Science",
                color: "blue",
                link: "https://www.nature.com/nmat/",
                title: "Harnessing Quantum Computing for Energy Materials",
                summary: "Research on modeling strongly correlated systems for next-gen battery technologies.",
                content: `
                    <p>Quantum Science helps us understand the "glue" that holds materials together. When we apply this to Computing, we can simulate chemicals that don't exist yet.</p>
                    <p><strong>Why it matters for you:</strong> By simulating atoms precisely, we can create batteries that don't need rare metals, making EVs and phones cleaner and cheaper for everyone.</p>
                    <p>This article explores how Scientists used Quantum computers to find a new type of crystal structure that improves solar panel efficiency by 20%.</p>
                `
            },
            {
                id: 3,
                category: "Cyber Security",
                color: "indigo",
                link: "https://arxiv.org/abs/2401.02183",
                title: "Developments in Superconducting Erasure Qubits",
                summary: "Research on qubits that provide error location info to hardware decoders.",
                content: `
                    <p>The biggest challenge in Quantum Computing is <strong>Noise</strong>. Even a tiny temperature change can break the "Science" of the qubit.</p>
                    <p><strong>Erasure Qubits:</strong> This is a major 2024-2026 breakthrough. These qubits act like a "check engine" light. Instead of just giving a wrong answer, they tell the computer exactly where the failure happened.</p>
                    <p>This allows the computer to fix itself, leading to <em>Reliable</em> Quantum Computing for the first time in history.</p>
                `
            }
        ];

        const grid = document.getElementById('article-grid');
        articles.forEach(art => {
            const card = document.createElement('div');
            card.className = "bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl p-6 article-card shadow-sm hover:shadow-md transition-all cursor-pointer flex flex-col justify-between";
            card.onclick = () => openReader(art.id);
            card.innerHTML = `
                <div>
                    <div class="flex items-center gap-2 text-${art.color}-600 dark:text-${art.color}-400 mb-3 text-xs font-bold uppercase tracking-widest">
                        <i data-lucide="info" class="w-4 h-4"></i>
                        ${art.category}
                    </div>
                    <h3 class="font-bold text-lg mb-3 leading-tight text-slate-800 dark:text-white">${art.title}</h3>
                    <p class="text-slate-600 dark:text-slate-400 text-sm mb-6">${art.summary}</p>
                </div>
                <div class="flex items-center gap-2 text-indigo-500 dark:text-indigo-400 text-sm font-bold">
                    Read Deep Dive <i data-lucide="chevron-right" class="w-4 h-4"></i>
                </div>
            `;
            grid.appendChild(card);
        });

        function openReader(id) {
            const art = articles.find(a => a.id === id);
            document.getElementById('modal-title').innerText = art.title;
            document.getElementById('modal-category').innerText = art.category;
            document.getElementById('modal-content').innerHTML = art.content;
            document.getElementById('modal-link').href = art.link;
            
            const modal = document.getElementById('reader-modal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            lucide.createIcons();
        }

        function closeReader() {
            const modal = document.getElementById('reader-modal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        const themeToggle = document.getElementById('theme-toggle');
        const sunIcon = document.getElementById('sun-icon');
        const moonIcon = document.getElementById('moon-icon');

        themeToggle.addEventListener('click', () => {
            document.documentElement.classList.toggle('dark');
            const isDark = document.documentElement.classList.contains('dark');
            sunIcon.classList.toggle('hidden', !isDark);
            moonIcon.classList.toggle('hidden', isDark);
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });

        window.onload = () => {
            lucide.createIcons();
            if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
                sunIcon.classList.remove('hidden');
                moonIcon.classList.add('hidden');
            }
        };
    </script>
</body>
</html>
